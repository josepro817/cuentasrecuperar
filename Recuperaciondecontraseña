<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Recuperar Contraseña</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="container">
    <h2>Recuperación de Contraseña</h2>
    <p>Completa los datos para cambiar tu contraseña</p>
    <form id="formRecuperar">
      <input type="email" id="correo" placeholder="Correo electrónico" required>
      <input type="password" id="contrasenaActual" placeholder="Contraseña actual" required>
      <input type="password" id="nuevaContrasena" placeholder="Nueva contraseña" required>
      <button type="submit">Enviar</button>
    </form>
    <div id="mensaje"></div>
  </div>
  <script src="script.js"></script>
</body>
</html>
